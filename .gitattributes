# Force LF line endings for shell scripts on all platforms.
# This prevents Windows from converting \n to \r\n (CRLF),
# which breaks bash shebangs and causes "exited with code 1" in Docker.
* text=auto eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
docker-compose.yml text eol=lf
.env text eol=lf
*.md text eol=lf