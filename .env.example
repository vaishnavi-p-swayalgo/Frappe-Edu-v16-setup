# =============================================================
#  Frappe v16 — Environment Configuration
#  Copy this to .env and fill in your values before deploying
# =============================================================

FRAPPE_VERSION=16
FRAPPE_USER=frappe
BENCH_NAME=frappe-bench

# Must contain a dot — used as the Frappe site name internally
SITE_NAME=erp.local

# Frappe Administrator login password
ADMIN_PASSWORD=demo@123

# MariaDB root password — pick something strong
DB_ROOT_PASSWORD=123@demo

# Your public domain — SSL will be auto-issued via Certbot on host
DOMAIN=playground.swayalgo.com
